# Copy this file to `.env` in this folder (`mobile/`) and fill in values.
# Never commit `.env`.
#
# Expo only exposes EXPO_PUBLIC_* to the JS bundle (not NEXT_PUBLIC_*).
# If Metro logs `NEXT_PUBLIC_*`, rename those lines to EXPO_PUBLIC_* here.

# Supabase — same project as `site/` — Dashboard → Project Settings → API
EXPO_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=YOUR_ANON_PUBLIC_KEY

# --- Later (uncomment when you wire these in code) ---
# EXPO_PUBLIC_FIREBASE_* — Firebase console (phone auth per deliverables)
